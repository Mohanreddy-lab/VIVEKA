# VIVEKA — Environment Variables
# Copy to .env and fill in values. All variables are optional unless noted.

# ── LLM provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama          # "ollama" (default, free, offline) | "gemini"
MANTHAN_MODEL=llama3.2      # Ollama model name (llama3.2 = fast & free)
                             # Other options: mistral:7b  qwen2.5-coder:1.5b
GOOGLE_API_KEY=              # Required only when LLM_PROVIDER=gemini

# ── Ollama server location ─────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434   # Override when Ollama runs in Docker or remote
                                     # Docker Desktop: http://host.docker.internal:11434

# ── Embeddings ────────────────────────────────────────────────────────────────
MANTHAN_EMBED_MODEL=all-MiniLM-L6-v2   # sentence-transformers model (downloads once)

# ── Pipeline caps ─────────────────────────────────────────────────────────────
MANTHAN_RECALL_K=200         # How many candidates FAISS returns (Stage 2)
MANTHAN_SCORING_N=50         # How many Stage 3 passes to Stage 4
MANTHAN_RERANK_N=50          # How many candidates the LLM reranks (Stage 4)
                             # Set to 8 for fast test runs, 50 for final runs

# ── Parallel rerank workers ───────────────────────────────────────────────────
MANTHAN_PARALLEL_WORKERS=5   # Simultaneous LLM calls (parallel mode only)
                             # Reduce to 2 if you see out-of-memory errors

# ── Stage 3 scoring weights ───────────────────────────────────────────────────
MANTHAN_W_EMBED=0.30         # Embedding (semantic) similarity weight
MANTHAN_W_SKILL=0.40         # Skill overlap weight
MANTHAN_W_SENIORITY=0.15     # Seniority fit weight
MANTHAN_W_ACTIVITY=0.15      # Activity / behaviour signal weight

# ── Hidden gem detection ──────────────────────────────────────────────────────
MANTHAN_GEM_THRESHOLD=0.55   # Min composite score to flag as hidden gem

# ── Stage 4 rerank blending ───────────────────────────────────────────────────
MANTHAN_BLEND_COMPOSITE=0.50 # Weight of Stage 3 composite in final score
MANTHAN_BLEND_LLM=0.50       # Weight of LLM score in final score

# ── Profile text window sent to LLM ───────────────────────────────────────────
MANTHAN_PROFILE_CHARS=900    # Max chars of profile text per LLM call

# ── API server (src/api.py) ────────────────────────────────────────────────────
MANTHAN_API_KEY=             # Leave blank to disable auth. Set a secret to enable.
MANTHAN_CORS_ORIGINS=*       # Comma-separated allowed origins. "*" = open (dev only)
                             # Production: https://yourdomain.com
